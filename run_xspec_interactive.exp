#!/usr/bin/expect -f
set timeout -1
spawn xspec
expect "XSPEC12>"
send "data 1:1 m1_final_grp.fits\r"
send "data 2:2 m2_final_grp.fits\r"
send "data 3:3 pn_final_grp.fits\r"
send "cpd /xserve\r"
send "setplot energy\r"
send "notice all\r"
send "ignore bad\r"
send "ignore 1-3:**-0.3 10.0-**\r"
send "@${env(MODEL_FILE)}\r"
interact
